# Copy to .env and fill in. All values are optional except the API key for LIVE mode.

# Required for the real Agent SDK manager. Without it, the board runs in MOCK mode.
ANTHROPIC_API_KEY=

# --- optional overrides ---
# Port for the local board UI (default 4173). Bound to 127.0.0.1 only.
# MANAGER_PORT=4173

# Which repo the manager operates on. Defaults to the folder this feature-folder sits in.
# MANAGER_REPO_DIR=/absolute/path/to/your/repo

# Model for the manager (default: the SDK's default). e.g. claude-sonnet-4-5, claude-opus-4-1
# MANAGER_MODEL=

# Permission strategy for the headless agent. Default: bypassPermissions (fully autonomous).
# Options: default | acceptEdits | dontAsk | bypassPermissions
# MANAGER_PERMISSION_MODE=bypassPermissions

# Force mock mode even with a key set (useful for demos): 1 to force on, 0 to force off.
# MANAGER_MOCK=

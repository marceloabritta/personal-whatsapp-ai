# ===== Claude (the secretary / router) =====
ANTHROPIC_API_KEY=sk-ant-xxxxx
CLAUDE_MODEL=claude-sonnet-5

# ===== Google (user OAuth) — Skills: calendar_action + task_action =====
# The refresh token must be minted with BOTH scopes (re-consent with both at once):
#   https://www.googleapis.com/auth/calendar   (calendar_action)
#   https://www.googleapis.com/auth/tasks       (task_action — Google Tasks)
# Keep the OAuth consent screen "In production" (a Testing token expires in ~7 days).
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxx
GOOGLE_REFRESH_TOKEN=1//xxxxx
GOOGLE_CALENDAR_ID=primary
# Which Google Tasks list to use. Defaults to the user's default list.
# GOOGLE_TASKLIST_ID=@default

# ===== AssemblyAI (audio transcription) — Skill: transcribe_audio =====
ASSEMBLYAI_API_KEY=xxxxx
# Audio language (AssemblyAI code). "en" = English, "pt" = Portuguese. Leave empty
# for auto-detection (swap language_code for language_detection in the skill).
ASSEMBLYAI_LANGUAGE=en

# ===== Flights (Kiwi) — Skill: flight_search =====
# There is NO provider API key: Kiwi's MCP endpoint (https://mcp.kiwi.com) is keyless.
# The currency asked of Kiwi. Defaults to BRL if unset.
FLIGHT_CURRENCY=BRL

# ===== Behavior =====
OWNER_NAME=User
# Trigger tag(s) that start the secretary in WhatsApp — comma-separated for more
# than one (e.g. a PT and an EN spelling), lowercase. Read from the environment
# (in the Docker stack this is set in docker-compose.yml, which overrides this
# file). @brain is intentionally retired.
#
# THIS IS THE SEED, NOT THE LAST WORD. The owner can change the tags by asking her
# ("@assistant, change your tag to @assist" — the `assistant_settings` skill). The
# changed list is STORED in Redis (secretary:settings:tags, no TTL) and WINS over this
# value at boot; the boot log says which source won. A restart does NOT undo a tag
# change — the store outlives it. To go back to this seed, clear the stored setting:
#   docker exec evolution_redis redis-cli DEL secretary:settings:tags
SECRETARY_TAG=@assistente,@assistant

# Conversation state (per-chat sessions for confirmations/clarifications).
# Defaults to the Redis already in the stack. Set REDIS_URL= (empty) to force the
# in-memory fallback (fine for local dev; state is lost on restart).
# REDIS_URL=redis://evolution_redis:6379

# ===== Link to Evolution (filled in by docker-compose) =====
# EVOLUTION_URL=http://api:8080
# EVOLUTION_APIKEY=...        (Evolution's AUTHENTICATION_API_KEY)
# EVOLUTION_INSTANCE=secretaria
